{
  "project": {
    "template_cst": "C:/path/to/shield_mesh_3x3_template.cst",
    "runs_dir": "runs_shield_mesh_3x3",
    "copy_template_per_run": true,
    "model_note": "3x3 shielding mesh. Keep geometry fixed except mesh_width and mesh_thickness."
  },
  "cst": {
    "mode": "local_gui",
    "connect_address": null,
    "save_after_parameter_update": true,
    "run_solver": true,
    "result_exports": [
      {
        "name": "s21_or_s11",
        "type": "todo",
        "note": "For shielding mesh, S21 is usually the key result. Export S21 as s21.csv or S11 as s11.csv after solver."
      }
    ]
  },
  "sweep": {
    "max_runs": 25,
    "parameters": [
      {
        "name": "mesh_width",
        "unit": "mm",
        "start": 0.2,
        "stop": 1.0,
        "step": 0.2
      },
      {
        "name": "mesh_thickness",
        "unit": "mm",
        "values": [0.035, 0.07, 0.105, 0.14, 0.175]
      }
    ]
  },
  "results": {
    "s11_file_patterns": [
      "s11.csv",
      "result_s11.csv",
      "s11.txt",
      "result_s11.txt",
      "*s11*.csv",
      "*S11*.csv",
      "*s11*.txt",
      "*S11*.txt"
    ],
    "s21_file_patterns": [
      "s21.csv",
      "result_s21.csv",
      "s21.txt",
      "result_s21.txt",
      "*s21*.csv",
      "*S21*.csv",
      "*s21*.txt",
      "*S21*.txt"
    ]
  },
  "scoring": {
    "target_frequency_ghz": 10.0,
    "s11_goal_db": -10.0,
    "primary_metric": "shielding_mesh_screening"
  }
}
